# Copy this file to .env and fill in real values. Never commit the real .env file.

# PostgreSQL connection string (AWS RDS in production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/billiards_arena

# JWT signing secret - generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Comma-separated list of allowed frontend origins (your Firebase Hosting URLs)
ALLOWED_ORIGINS=http://localhost:5173,https://your-project.web.app,https://your-project.firebaseapp.com

# Optional: S3 bucket for table/menu item images
S3_BUCKET=
AWS_REGION=ap-south-1

# Revenue donut colour threshold (INR)
DAILY_TARGET_GREEN_THRESHOLD=2000

# Seed script credentials - OPTIONAL overrides.
# By default these are read from backend/app/club_config.py (the single
# white-label config file). Only set these if you want to override that
# file without editing source, e.g. in a CI/CD pipeline.
# ADMIN_USERNAME=
# ADMIN_PASSWORD=
# ADMIN_FULL_NAME=
# ADMIN_CLUB_NAME=
