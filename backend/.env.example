# Copy this file to .env and fill in real values. Never commit the real .env file.

# MongoDB Atlas connection string. In Atlas: Database -> Connect -> Drivers ->
# Node.js, copy the string, and replace <password> with your database user's
# password. Add the database name before the query string, e.g. ".../billiards_arena?retryWrites=...".
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/billiards_arena?retryWrites=true&w=majority

# JWT signing secret - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=replace-this-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Comma-separated list of allowed frontend origins (your Firebase Hosting URLs)
ALLOWED_ORIGINS=http://localhost:5173,https://your-project.web.app,https://your-project.firebaseapp.com

# Server port
PORT=8000

# Revenue donut colour threshold (INR)
DAILY_TARGET_GREEN_THRESHOLD=2000

# Seed script credentials - OPTIONAL overrides.
# By default these are read from src/clubConfig.js (the single white-label
# config file). Only set these if you want to override that file without
# editing source, e.g. in a CI/CD pipeline.
# ADMIN_USERNAME=
# ADMIN_PASSWORD=
# ADMIN_FULL_NAME=
# ADMIN_CLUB_NAME=
